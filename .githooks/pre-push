#!/bin/sh
# Pre-push hook for QF Workflow SDK: validate required SDK docs before pushing.

set -e

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

for file in README.md agentic_dictionary.md docs/sdk_plan.md docs/handoff.md; do
  if [ ! -s "$file" ]; then
    echo "Required SDK document missing or empty: $file"
    exit 1
  fi
done

for agent in agents/*; do
  if [ -d "$agent" ]; then
    for file in README.md prompt.md instructions.md tasks.md; do
      if [ ! -s "$agent/$file" ]; then
        echo "Public agent contract missing or empty: $agent/$file"
        exit 1
      fi
    done
  fi
done

echo "QF Workflow SDK pre-push checks passed."
