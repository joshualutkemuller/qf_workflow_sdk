#!/bin/sh
# Pre-commit hook for QF Workflow SDK: run lightweight repository checks.

set -e

ROOT_DIR=$(git rev-parse --show-toplevel)
cd "$ROOT_DIR"

if git diff --cached --name-only --diff-filter=ACMR | grep -Eq '(^|/)\.DS_Store$'; then
  echo "Remove .DS_Store files before committing."
  exit 1
fi

for file in README.md agentic_dictionary.md docs/sdk_plan.md docs/handoff.md; do
  if [ ! -f "$file" ]; then
    echo "Required SDK document missing: $file"
    exit 1
  fi
done

for agent in agents/*; do
  if [ -d "$agent" ]; then
    for file in README.md prompt.md instructions.md tasks.md; do
      if [ ! -f "$agent/$file" ]; then
        echo "Public agent contract missing: $agent/$file"
        exit 1
      fi
    done
  fi
done

sh -n setup-hooks.sh
for hook in .githooks/*; do
  sh -n "$hook"
done

echo "QF Workflow SDK pre-commit checks passed."
